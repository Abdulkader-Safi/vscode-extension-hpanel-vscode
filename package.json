{
  "name": "svelte-starter",
  "displayName": "svelte-starter",
  "description": "A VS Code extension starter with Svelte and TailwindCSS",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svelte-starter.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "svelte-starter.openSvelteView",
        "title": "Open Svelte View"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "esbuild-plugin-inline-import": "^1.1.0",
    "esbuild-svelte": "^0.9.4",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.10",
    "postcss-cli": "^11.0.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "svelte-spa-router": "^5.0.1"
  }
}